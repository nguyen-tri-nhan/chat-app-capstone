.gitmodules

.vscode/

# Python — single uv workspace venv/lock live at the repo root (agents/, agents_langgraph/,
# shared/ are workspace members); per-member .venv/ entries are a safety net in case one gets
# created outside the workspace flow.
.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
agents/.venv/
agents/.env
agents_langgraph/.venv/
agents_langgraph/.env
shared/.venv/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# OS
.DS_Store
