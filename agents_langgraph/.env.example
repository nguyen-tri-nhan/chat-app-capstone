LLM_BASE_URL=https://opencode.ai/zen/v1/
LLM_MODEL=opencode/deepseek-v4-flash-free
LLM_API_KEY=your_opencode_zen_api_key_here

# Separate workspace dir from agents/'s default (/tmp/deep-analyst) so both engines can run
# side by side locally (non-Docker) without artifact collisions. shared/tools.py reads this.
WORKSPACE_BASE=/tmp/deep-analyst-langgraph
